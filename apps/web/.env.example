# =============================================================================
# DocAI Web App — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# =============================================================================

# ─── LLM API Keys (at least one required) ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ─── Authentication (optional) ───────────────────────────────────────────────
# If set, requests must include this token in the x-auth-token header.
# Leave empty for open access.
DEMO_ACCESS_TOKEN=

# ─── Rate Limiting (optional) ────────────────────────────────────────────────
# Set to "true" to enable rate limiting
ENABLE_RATE_LIMIT=false
# Max requests per window (default: 20)
RATE_LIMIT_MAX_REQUESTS=20
# Window duration in milliseconds (default: 3600000 = 1 hour)
RATE_LIMIT_WINDOW_MS=3600000
