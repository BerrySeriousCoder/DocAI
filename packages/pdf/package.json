{
    "name": "@docai/pdf",
    "version": "0.1.0",
    "private": true,
    "description": "PDF extraction, highlight resolution, and LLM integration library",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc-watch --onSuccess \"echo 'Backend Built Successfully'\"",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@google/genai": "^1.50.1",
        "openai": "^6.34.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "tsc-watch": "^7.2.0",
        "typescript": "^5.0.0"
    }
}